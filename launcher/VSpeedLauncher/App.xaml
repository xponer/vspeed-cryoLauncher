<Application x:Class="VSpeedLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown"
             Startup="OnStartup">
    <Application.Resources>
        <!-- Dark theme palette — matches the user's existing Prism dark mode. -->
        <SolidColorBrush x:Key="BgBrush"      Color="#1E1F22"/>
        <SolidColorBrush x:Key="PanelBrush"   Color="#2B2D31"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#5865F2"/>
        <SolidColorBrush x:Key="OkBrush"      Color="#3BA55C"/>
        <SolidColorBrush x:Key="WarnBrush"    Color="#ED4245"/>
        <SolidColorBrush x:Key="FgBrush"      Color="#F2F3F5"/>
        <SolidColorBrush x:Key="DimBrush"     Color="#949BA4"/>
    </Application.Resources>
</Application>
